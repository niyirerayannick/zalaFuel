{
  "name": "atms-desktop",
  "productName": "ATMS",
  "version": "1.0.0",
  "description": "Electron desktop wrapper for the Afrilott Transport Management System",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^37.2.6",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.atms.desktop",
    "productName": "ATMS",
    "artifactName": "ATMS Setup.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json",
      "build/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
