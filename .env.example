## ZALA/ECO ENERGY
## Environment Variables
## Copy this file to .env and fill in real values.
## For Coolify: paste these into the Environment Variables section.

# Django Core
DJANGO_SETTINGS_MODULE=nopra_fuel.settings.production
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ATMS_PUBLIC_BASE_URL=https://yourdomain.com
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
TIME_ZONE=Africa/Johannesburg

# Database (PostgreSQL)
# Coolify auto-injects this when you link a PostgreSQL service.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://zalaeco:zalaeco@db:5432/zalaeco
DATABASE_SSL_REQUIRE=False

# Redis / Celery (optional)
# Leave blank when deploying only Django + PostgreSQL on Coolify.
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_FROM_NAME=ZALA/ECO ENERGY Notifications
DEFAULT_FROM_EMAIL=no-reply@zalaeco.local

# Site
SITE_ID=1
TAILWIND_APP_NAME=theme

# Cloudinary (optional)
USE_CLOUDINARY=False
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Sentry (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_PII=False

# Security (production)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Twilio WhatsApp Integration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+14155238886
TWILIO_STATUS_CALLBACK_URL=https://yourdomain.com/api/whatsapp/status/

# Superuser (auto-created on first deploy)
DJANGO_SUPERUSER_FULL_NAME=ZALA/ECO ENERGY Administrator
DJANGO_SUPERUSER_EMAIL=admin@zalaeco.local
DJANGO_SUPERUSER_PASSWORD=change-me
